# Core Secrets (required)
JWT_SECRET_KEY=
SECRET_KEY=

# LLM Provider
# Development:  "ollama" (runs locally, no API key, no rate limits while building)
# Production:   "openrouter" (single gateway to all free-tier LLMs on Render)
LLM_PROVIDER=ollama

# Primary model — the fallback chain kicks in automatically if this fails.
#
#   When LLM_PROVIDER=ollama:
#     LLM_MODEL=qwen2.5:3b
#
#   When LLM_PROVIDER=openrouter (recommended primary):
#     LLM_MODEL=google/gemma-4-31b-it:free    ← best for RAG (256K ctx)
#
#   Full fallback chain (automatic, no config needed):
#     1. google/gemma-4-31b-it:free      Primary   — 256K context, strong instruction following
#     2. openai/gpt-oss-120b:free        Backup    — highest capacity free model
#     3. openai/gpt-oss-20b:free         Fallback  — fast MoE, reliable under load
#     4. openrouter/free                 Emergency — OpenRouter picks any available free model
#
#   If primary is rate-limited or offline, VaultIQ automatically tries
#   the next model in the chain. The app stays alive.
LLM_MODEL=qwen2.5:3b

# OpenRouter AAPI key — only when LLM_PROVIDER=openrouter
# GEt free at https://openrouter.ai/keys
# Leave blank got local dev
OPENROUTER_API_KEY=

HF_TOKEN=

# LLM call tuning
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# RAG pipeline tuning
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=5

# Rate limiting
# applies to /ask only. flask-limiter str syntax e.g. "10 per minute"
ASK_RATE_LIMIT=10 per minute

# Logging
LOG_LEVEL=INFO
