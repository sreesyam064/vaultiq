# VaultIQ — Development Environment

# Dev uses Ollama locally — no API keys needed.

# Core Secrets
JWT_SECRET_KEY=jwt-secret-key-here
SECRET_KEY=secret-key-here

# HuggingFace Token
HF_TOKEN=huggingface-token-here

# LLM (set y docker-compose.dev.yml, listed here for reference)
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:3b
OLLAMA_HOST=http://ollama:11434

# Optional tuning
LOG_LEVEL=DEBUG
