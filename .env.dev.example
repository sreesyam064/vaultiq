# VaultIQ — Development Environment

# Dev uses Ollama locally — no API keys needed.

APP_ENV=development

# Core Secrets
JWT_SECRET_KEY=jwt-secret-key-here
SECRET_KEY=secret-key-here

# HuggingFace Token
HF_TOKEN=huggingface-token-here

# LLM (set y docker-compose.dev.yml, listed here for reference)
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:3b
OLLAMA_HOST=http://ollama:11434

# Optional tuning
LOG_LEVEL=DEBUG
# Safe to enable locally: this is a single-process dev run, not Gunicorn
ENABLE_FILE_LOGGING=true

# Upload limits (dev defaults — same as prod, override if useful for testing)
# MAX_UPLOAD_SIZE_MB=20
# MAX_FILES_PER_UPLOAD=10
# INGEST_BATCH_SIZE=32

# Auth rate limit (dev default — loosen if it gets in the way while testing)
# AUTH_RATE_LIMIT=5 per minute