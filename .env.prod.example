# VaultIQ — Production Environment

# Prod uses OpenRouter API — Ollama not needed.
# Fill in all values before running.

# Environment — Required. Turns on strict startup checks: app will refuse to boot 
# if it would otherwise silently fall back to SQLite or local disk storage.
APP_ENV=production

# Core Secrets (required)
JWT_SECRET_KEY=jwt-secret-key-here
SECRET_KEY=secret-key-here

# Database (Neon)
# Get this from Neon project dashboard -> Connection Details.
# Neon guves "pooled" connection string (recommended for app's normal rrequest traffic 
# goes through pgbouncer) and "direct" one (use direct string only for running `flask db upgrade`,
# since migrations/DDL can behave oddly through a transaction-mode pooler).
# If DATABASE_URL is unset, app falls back to local SQLite automatically.
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# File Storage (Cloudflare R2)
# Get this from Cloudflare dashboard -> R2 -> Manage R2 API Tokens.
# If all 4 are unset, app falls back to local disk automatically (fine for dev, not for prod
# on Render/most PaaS — their local disk is ephemeral and wiped on every redeploy).
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=r2-access-key-id-here
R2_SECRET_ACCESS_KEY=r2-secret-access-key-here
R2_BUCKET_NAME=vaultiq-uploads

# HuggingFace Token
HF_TOKEN=huggingface-token-here

# OpenRouter (required for prod)  
OPENROUTER_API_KEY=openrouter-api-key-here

# LLM Provider


# LLM model (optional — defaults to Gemma 4 31B free)
#   Fallback chain kicks in automatically if this model is rate-limited:
#       Primary:   google/gemma-4-31b-it:free
#       Backup:    openai/gpt-oss-120b:free
#       Fallback:  openai/gpt-oss-20b:free
#       Emergency: openrouter/free
LLM_MODEL=google/gemma-4-31b-it:free

# LLM config (set by docker-compose.prod.yml — listed here for reference)
# LLM_PROVIDER=openrouter
# LLM_TIMEOUT_SECONDS=30
# LLM_MAX_RETRIES=2
# ASK_RATE_LIMIT=10 per minute

# Applies to /login and /register — previously unlimited, leaving both
# open to brute-force / credential-stuffing.
# AUTH_RATE_LIMIT=5 per minute

# Upload limits
# MAX_UPLOAD_SIZE_MB=20
# MAX_FILES_PER_UPLOAD=10

# Batch size for embedding chunks during ingestion — bounds peak memory
# usage regardless of PDF size.
# INGEST_BATCH_SIZE=32
# LOG_LEVEL=INFO
# File logging is OFF by default (correct for Docker/Gunicorn). Leave unset in production.
ENABLE_FILE_LOGGING=false
